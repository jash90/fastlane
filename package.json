{
  "name": "fastlane-init",
  "version": "1.6.2",
  "description": "Interactive CLI to auto-configure Fastlane for React Native projects",
  "type": "module",
  "main": "dist/cli.js",
  "files": [
    "dist"
  ],
  "bin": {
    "fastlane-init": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun run src/cli.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0",
    "google-auth-library": "^10.6.2",
    "inquirer": "^9.2.15",
    "jsonwebtoken": "^9.0.2",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "fastlane",
    "react-native",
    "ios",
    "android",
    "ci-cd",
    "cli"
  ],
  "license": "MIT"
}
